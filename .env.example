# ──────────────────────────────────────────────────────────────────────────────
# Sentinel Fusion — Environment Configuration
#
# Copy this file to .env and adjust values for your environment.
# All variables are optional — the defaults shown here are used if unset.
#
#   cp .env.example .env
# ──────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────

# Path to the SQLite database file.
# Use an absolute path in production to avoid working-directory ambiguity.
# Use :memory: for fully in-memory testing (data lost on shutdown).
SENTINEL_DB=./data/sentinel.db

# ── API Server ────────────────────────────────────────────────────────────────

# Bind address. 0.0.0.0 listens on all interfaces (required for Docker).
SENTINEL_HOST=0.0.0.0

# TCP port the API server listens on.
SENTINEL_PORT=8000

# Number of Uvicorn worker processes.
# Keep at 1 with SQLite (WAL mode handles concurrent reads, not writes).
SENTINEL_WORKERS=1

# Log verbosity: debug | info | warning | error | critical
SENTINEL_LOG_LEVEL=info

# ── Application Behaviour ────────────────────────────────────────────────────

# Runtime environment label: development | staging | production
# Affects error verbosity and future feature flags.
SENTINEL_ENV=development

# Enable FastAPI debug mode — shows full tracebacks in API responses.
# NEVER enable in production.
SENTINEL_DEBUG=false

# Default event retention window (days) used by POST /api/v1/pipeline/purge
# when no explicit value is supplied.
SENTINEL_RETENTION_DAYS=90

# Comma-separated list of allowed CORS origins.
# In production, replace * with your actual frontend domain(s).
# SENTINEL_CORS_ORIGINS=https://yourdomain.com,https://app.yourdomain.com
SENTINEL_CORS_ORIGINS=*

# ── Authentication ────────────────────────────────────────────────────────────

# Require X-API-Key header on all API requests.
# Leave empty to disable authentication (development only).
# In production: SENTINEL_API_KEY=$(openssl rand -hex 32)
SENTINEL_API_KEY=

# ── Threat Intelligence ───────────────────────────────────────────────────────

# AbuseIPDB API key for live IP reputation lookups.
# Leave empty to use built-in seed data only (no outbound calls).
# Free tier at https://www.abuseipdb.com/api.html
SENTINEL_ABUSEIPDB_KEY=

# Enable live geolocation via ip-api.com (no key required).
# Set to true to enrich events with country, city, and ISP.
SENTINEL_GEO_ENABLED=false

# Cache TTL (seconds) for IP reputation and geo results.
SENTINEL_INTEL_CACHE_TTL=3600

# HTTP timeout (seconds) for outbound intelligence API calls.
SENTINEL_INTEL_TIMEOUT=5

# ── Detection Thresholds ──────────────────────────────────────────────────────

# Generic brute force: minimum failures before alert fires.
SENTINEL_BRUTE_FORCE_THRESHOLD=3
SENTINEL_BRUTE_FORCE_WINDOW=300

# WINLOG-001: Event ID 4625 burst detection.
SENTINEL_WINLOG_BRUTE_FORCE_THRESHOLD=5
SENTINEL_WINLOG_BRUTE_FORCE_WINDOW=60

# WINLOG-002: Max seconds between last 4625 failure and a 4624 success.
SENTINEL_WINLOG_BRUTE_FORCE_SUCCESS_WINDOW=120

# WINLOG-003: Account backdoor correlation window.
SENTINEL_WINLOG_ACCOUNT_BACKDOOR_WINDOW=300

# WINLOG-004: Lateral movement (explicit credentials) window.
SENTINEL_WINLOG_LATERAL_WINDOW=120

# WINLOG-005: Privilege escalation detection window.
SENTINEL_WINLOG_PRIVESC_WINDOW=30

# Minimum alert confidence (0.0–1.0) to influence the executive verdict.
SENTINEL_VERDICT_CONFIDENCE_FLOOR=0.3

# ── Elasticsearch SIEM Integration ───────────────────────────────────────────

# Enable forwarding of alerts, scores, and hunt findings to Elasticsearch.
# Requires Elasticsearch running (locally or via docker-compose up).
SENTINEL_ELASTIC_ENABLED=false

# Elasticsearch base URL.
SENTINEL_ELASTIC_URL=http://localhost:9200

# API key for authenticated Elasticsearch instances (Elastic Cloud, secured clusters).
# Leave empty for local unauthenticated instances.
SENTINEL_ELASTIC_API_KEY=

# Prefix for all Sentinel_Fusion index names.
# Indices created: {prefix}-alerts-YYYY.MM.DD, {prefix}-scores-YYYY.MM.DD,
#                  {prefix}-hunt-YYYY.MM.DD,   {prefix}-runs-YYYY.MM.DD
SENTINEL_ELASTIC_INDEX_PREFIX=sentinel

# HTTP timeout (seconds) for Elasticsearch API calls.
SENTINEL_ELASTIC_TIMEOUT=5
