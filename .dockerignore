# Version control
.git
.gitignore

# Python cache
__pycache__
*.py[cod]
*.pyo
.pytest_cache
.mypy_cache
.ruff_cache

# Virtual environments
.venv
venv
env

# Test / dev artifacts
tests/
requirements-dev.txt
*.coverage
.coverage
htmlcov/

# Local database files (volume-mounted in Docker)
*.db
*.db-shm
*.db-wal
# Keep data/samples/ — seed script uses them at first boot
data/*.db

# Environment files with secrets
.env
.env.*
!.env.example

# Editor / OS
.DS_Store
*.swp
*.swo
.idea/
.vscode/

# Docs and assets (not needed at runtime)
docs/
assets/
